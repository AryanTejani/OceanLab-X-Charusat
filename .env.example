# ============================================================
# MeetMind AI — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will NEVER be committed.
#
# Usage: cp .env.example .env.local
# ============================================================


# ============================================================
# AUTHENTICATION — Clerk
# Get keys at: https://clerk.com → Dashboard → API Keys
# Create a new app, then copy the keys from the "API Keys" tab
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (keep these as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/


# ============================================================
# VIDEO CONFERENCING — Stream.io
# Get keys at: https://getstream.io → Dashboard → Create App → API Keys
# Create an app, select "Video & Audio", then copy the keys
# ============================================================
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_SECRET_KEY=


# ============================================================
# SPEECH-TO-TEXT (PRIMARY) — Deepgram
# Get key at: https://console.deepgram.com → API Keys → Create Key
# Free tier: 200 hours/month
# Used for: Live meeting transcription + audio file upload transcription
# NOTE: Server-side only (not NEXT_PUBLIC_) for security
# ============================================================
DEEPGRAM_API_KEY=


# ============================================================
# SPEECH-TO-TEXT (ALTERNATIVE) — AssemblyAI
# Get key at: https://www.assemblyai.com → API Keys
# Free tier available. Used as backup + for live captions feature
# ============================================================
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_REALTIME_MODEL=universal-2


# ============================================================
# AI Q&A CHATBOT — Google Gemini
# Get key at: https://aistudio.google.com → Get API Key
# Free tier available. Used for the Q&A chatbot on transcripts
# ============================================================
GEMINI_API_KEY=


# ============================================================
# AI INSIGHTS (SUMMARY, ACTION ITEMS, DECISIONS) — Groq
# Get key at: https://console.groq.com → API Keys → Create Key
# Free tier: Very generous. Model: llama-3.3-70b-versatile
# Used for: Meeting summary, action items, decisions, timeline, podcast script
# ============================================================
GROQ_API_KEY=


# ============================================================
# PODCAST TEXT-TO-SPEECH — ElevenLabs
# Get key at: https://elevenlabs.io → Profile → API Key
# Free tier: 10,000 characters/month (~5-8 meeting podcasts)
# Used for: Converting meeting summaries into podcast audio
# ============================================================
ELEVENLABS_API_KEY=


# ============================================================
# DATABASE — MongoDB
# Get connection string at: https://cloud.mongodb.com
# Steps: Create free cluster → Connect → Drivers → Copy connection string
# Replace <username>, <password>, and <dbname> in the URI
# Local alternative: mongodb://localhost:27017/meetmind
# ============================================================
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/meetmind?retryWrites=true&w=majority


# ============================================================
# APP URLs
# For local dev: http://localhost:3000
# For production: your Vercel URL (e.g. https://meetmind.vercel.app)
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000


# ============================================================
# CAPTIONS PROXY (optional — for AssemblyAI live captions)
# Only needed if running the captions proxy server locally
# Run with: node server/captions-proxy.js
# ============================================================
NEXT_PUBLIC_CAPTIONS_PROVIDER=assemblyai
CAPTIONS_PROXY_PORT=8787
NEXT_PUBLIC_CAPTIONS_PROXY_PORT=8787
