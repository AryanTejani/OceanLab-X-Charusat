# ============================================================
# MeetMind AI — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Usage: cp .env.example .env
#
# NOTE: In the monorepo, both frontend and backend read from
# the root .env file. This file documents backend-specific vars.
# ============================================================


# ============================================================
# SERVER
# ============================================================
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000


# ============================================================
# AUTHENTICATION — Clerk
# Get keys at: https://clerk.com → Dashboard → API Keys
# Backend uses CLERK_SECRET_KEY to verify JWTs from frontend
# ============================================================
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...


# ============================================================
# DATABASE — PostgreSQL (Supabase)
# Get connection string at: https://supabase.com → Project → Settings → Database → URI
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# NOTE: If password contains @, encode it as %40
# Tables are auto-created on first run (synchronize: true)
# ============================================================
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres


# ============================================================
# SPEECH-TO-TEXT — Deepgram
# Get key at: https://console.deepgram.com → API Keys → Create Key
# Free tier: 200 hours/month
# Used for: Audio file upload transcription + token endpoint
# ============================================================
DEEPGRAM_API_KEY=


# ============================================================
# SPEECH-TO-TEXT (ALTERNATIVE) — AssemblyAI
# Get key at: https://www.assemblyai.com → API Keys
# Used for: Live transcription via Socket.IO + captions token
# ============================================================
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_REALTIME_MODEL=universal-2


# ============================================================
# AI Q&A CHATBOT — OpenRouter
# Get key at: https://openrouter.ai → Keys
# Free tier available. Used for Q&A over meeting transcripts.
# Default model: google/gemini-2.0-flash-lite:free
# ============================================================
OPENROUTER_API_KEY=


# ============================================================
# AI INSIGHTS (SUMMARY, ACTION ITEMS, DECISIONS) — Groq
# Get key at: https://console.groq.com → API Keys → Create Key
# Free tier: Very generous. Model: llama-3.3-70b-versatile
# Used for: Meeting summary, action items, decisions, timeline, podcast script
# ============================================================
GROQ_API_KEY=


# ============================================================
# PODCAST TEXT-TO-SPEECH — ElevenLabs
# Get key at: https://elevenlabs.io → Profile → API Key
# Free tier: 10,000 characters/month
# Used for: Converting meeting summaries into podcast audio
# ============================================================
ELEVENLABS_API_KEY=


# ============================================================
# PODCAST AUDIO STORAGE — Cloudinary
# Get credentials at: https://cloudinary.com → Dashboard
# Free tier: 25GB storage, 25GB bandwidth/month
# Used for: Storing generated podcast MP3 files
# ============================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
