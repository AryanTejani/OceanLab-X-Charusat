{
  "manifest_version": 3,
  "name": "MeetMind AI",
  "version": "1.0.0",
  "description": "Send a bot to record and analyze any meeting — one click from Google Meet, Zoom, or Teams",
  "permissions": ["activeTab", "storage", "cookies"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "https://*.ngrok-free.dev/*",
    "https://*.ngrok.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*-*-*",
        "https://*.zoom.us/j/*",
        "https://teams.microsoft.com/l/meetup-join/*",
        "https://teams.live.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
