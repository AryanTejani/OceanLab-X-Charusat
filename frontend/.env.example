# ============================================================
# MeetMind AI — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Usage: cp .env.example .env.local
# ============================================================


# ============================================================
# AUTHENTICATION — Clerk
# Get keys at: https://clerk.com → Dashboard → API Keys
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (keep these as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/


# ============================================================
# VIDEO CONFERENCING — Stream.io
# Get keys at: https://getstream.io → Dashboard → API Keys
# ============================================================
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_SECRET_KEY=


# ============================================================
# BACKEND API URL
# Local dev: http://localhost:3001
# Production: your deployed backend URL
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:3001


# ============================================================
# APP URLs
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000


# ============================================================
# CAPTIONS (optional)
# ============================================================
NEXT_PUBLIC_CAPTIONS_PROVIDER=assemblyai
NEXT_PUBLIC_CAPTIONS_PROXY_PORT=8787
